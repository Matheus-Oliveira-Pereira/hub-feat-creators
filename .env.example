# ===========================================================================
# HUB Feat Creator — environment variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# ===========================================================================

# ---------------------------------------------------------------------------
# Backend (Spring Boot — apps/api)
# ---------------------------------------------------------------------------

# PostgreSQL
DATABASE_URL=jdbc:postgresql://localhost:5432/hub_feat_creators
DATABASE_USERNAME=hub_app
DATABASE_PASSWORD=changeme

# Auth (JWT)
JWT_SECRET=replace-with-256-bit-random-secret
JWT_EXPIRATION_MINUTES=60

# CORS — origens permitidas (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Email (PRD-004) — SMTP relay multi-conta
# Chave AES-256 (32 bytes) para criptografar senhas SMTP em repouso
# Gere com: openssl rand -base64 32 | head -c 32
EMAIL_KEY=dev-only-not-for-prod-32-byte-aes-key
# Spring Mail padrão (usado apenas para LGPD notify e digest; envios de usuário usam contas SMTP cadastradas)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=sistema@hub-feat-creators.com
SPRING_MAIL_PASSWORD=changeme

# Observability
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Feature flags
FEATURE_AI_MATCH_ENABLED=false
FEATURE_COMPLIANCE_STRICT=true   # LGPD: valida base legal obrigatória; false só em dev/testes

# ---------------------------------------------------------------------------
# Frontend (Next.js — apps/web)
# ---------------------------------------------------------------------------

NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_ENV=development

# ---------------------------------------------------------------------------
# Memory Layer (L4)
# ---------------------------------------------------------------------------

# pgvector (opcional — usar quando memória for compartilhada entre devs)
# PGVECTOR_PASSWORD=changeme

# Embeddings (opcional — só se sair do modelo local all-MiniLM-L6-v2)
# OPENAI_API_KEY=sk-...
# VOYAGE_API_KEY=pa-...

# ---------------------------------------------------------------------------
# Integrações sociais (Fase 3 — match IA)
# ---------------------------------------------------------------------------

# INSTAGRAM_GRAPH_TOKEN=
# YOUTUBE_DATA_API_KEY=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
